<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.AppNotepad" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">#B2D4B2</item> <!-- Sage Green -->
        <item name="colorSecondary">#FAFAFA</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
    </style>

    <style name="Theme.App.Starting" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">#FAFAFA</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_splash_logo</item>
        <item name="postSplashScreenTheme">@style/Theme.AppNotepad</item>
    </style>
</resources>
